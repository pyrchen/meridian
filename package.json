{
  "name": "meridian",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Meridian — утренний дайджест значимых новостей (крипта, ИИ, разработка, бизнес) + приватный арбитражный сканер. PWA, без логина, бесплатный хостинг.",
  "scripts": {
    "dev": "vite",
    "news": "node scripts/fetch-news.mjs",
    "build": "node scripts/fetch-news.mjs && vite build",
    "build:site": "vite build",
    "preview": "vite preview --host",
    "icons": "node scripts/gen-icons.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.33.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.5",
    "workbox-window": "^7.4.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
